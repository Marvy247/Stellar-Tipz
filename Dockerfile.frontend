FROM node:20-bookworm AS builder

WORKDIR /app
COPY frontend-scaffold/package*.json ./
RUN npm ci --legacy-peer-deps
COPY frontend-scaffold/ .
RUN npm run build

FROM node:20-bookworm AS dev

WORKDIR /app
COPY frontend-scaffold/package*.json ./
RUN npm ci --legacy-peer-deps
COPY frontend-scaffold/ .

EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
