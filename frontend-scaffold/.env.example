# Soroban RPC URL (optional - overrides default network RPC URLs)
# If not set, will use default URLs based on VITE_NETWORK
# Example: https://soroban-testnet.stellar.org
# VITE_SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.gateway.fm

# Horizon URL for Stellar network operations (optional)
# Default: https://horizon-testnet.stellar.org
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase for the Stellar network (optional)
# Default: Test SDF Network ; September 2015
# For mainnet: public network
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract ID for the deployed smart contract (REQUIRED)
# Must be a valid Stellar contract address starting with 'C'
# Example format: CABC...DEFG (56 characters)
VITE_CONTRACT_ID=

# Network type: TESTNET, FUTURENET, or MAINNET (optional)
# Default: TESTNET
VITE_NETWORK=TESTNET

# Application URL (used for CORS, redirects, and canonical URLs)
# Issue #737: Required for custom domain deployments
VITE_APP_URL=https://your-domain.com

# Use mock data for development/testing (optional)
# Default: false
VITE_USE_MOCK_DATA=false

# Sentry DSN for error tracking (optional)
# If not set, error tracking will be disabled
# Get your DSN from: https://sentry.io
# VITE_SENTRY_DSN=

# Feature flags (prefix with VITE_FLAG_)
# VITE_FLAG_BATCH_TIPS=true
# VITE_FLAG_NEW_DASHBOARD=false
# VITE_FLAG_DARK_MODE=auto